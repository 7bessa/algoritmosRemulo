programa
{
    funcao inicio()
    {
        real x, y

        escreva("Distancia do Saltitao: ")
        leia(x)

        escreva("Distancia do Pula-Pula: ")
        leia(y)

        se (x > y)
        {
            escreva("Saltitao")
        }
        senao
        {
            escreva("Pula-Pula")
        }
    }
}
